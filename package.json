{
  "name": "swiftlocal",
  "version": "0.3.0",
  "private": true,
  "author": "SwiftLocal",
  "description": "快轉通 SwiftLocal - Your Local All-in-One File Converter",
  "main": "desktop/main.js",
  "scripts": {
    "start": "node scripts/serve.js",
    "desktop": "electron .",
    "backend": "node scripts/start-backend.js",
    "backend:win": "scripts/start-backend.cmd",
    "dev:all": "start \"SwiftLocal Backend\" cmd /c \"npm run backend:win\" && npm run start",
    "pack:win": "node scripts/pack-win.js --win portable nsis",
    "pack:win:dir": "node scripts/pack-win.js --win --dir",
    "pack:win:portable": "node scripts/pack-win.js --win portable",
    "pack:win:installer": "node scripts/pack-win.js --win nsis",
    "pack:win:full": "node scripts/build-win-full.js portable installer",
    "pack:win:full:dir": "node scripts/build-win-full.js dir",
    "pack:win:full:portable": "node scripts/build-win-full.js portable",
    "pack:win:full:installer": "node scripts/build-win-full.js installer",
    "pack:mac": "electron-builder --config electron-builder.config.js --mac dmg",
    "pack:mac:dir": "electron-builder --config electron-builder.config.js --mac --dir",
    "pack:mac:dmg": "electron-builder --config electron-builder.config.js --mac dmg",
    "bundle:mac:tools": "node scripts/bundle-mac-tools.js",
    "pack:mac:full": "node scripts/build-mac-full.js dmg",
    "pack:mac:full:dir": "node scripts/build-mac-full.js dir",
    "pack:mac:full:dmg": "node scripts/build-mac-full.js dmg",
    "pack:mac:signed": "SWIFTLOCAL_MAC_SIGN=1 electron-builder --config electron-builder.config.js --mac dmg",
    "pack:mac:dir:signed": "SWIFTLOCAL_MAC_SIGN=1 electron-builder --config electron-builder.config.js --mac --dir",
    "pack:mac:dmg:signed": "SWIFTLOCAL_MAC_SIGN=1 electron-builder --config electron-builder.config.js --mac dmg",
    "pack:mac:full:signed": "SWIFTLOCAL_MAC_SIGN=1 node scripts/build-mac-full.js dmg",
    "pack:mac:full:dir:signed": "SWIFTLOCAL_MAC_SIGN=1 node scripts/build-mac-full.js dir",
    "pack:mac:full:dmg:signed": "SWIFTLOCAL_MAC_SIGN=1 node scripts/build-mac-full.js dmg",
    "test": "node scripts/run-tests.js",
    "test:js": "node --test tests/desktop/backend.test.js",
    "test:py": "node -e \"const {spawnSync}=require('child_process'); const r=spawnSync(process.platform==='win32'?'py':'python3', process.platform==='win32'?['-3','-m','unittest','tests.backend.test_core','-v']:['-m','unittest','tests.backend.test_core','-v'],{stdio:'inherit',shell:true}); process.exit(r.status||0)\"",
    "smoke": "node scripts/smoke-release.js",
    "typecheck": "node --check frontend/app.js && node --check desktop/main.js && node --check desktop/preload.js && node --check desktop/backend.js && node --check scripts/smoke-release.js && node --check scripts/run-tests.js && node --check scripts/ensure-tessdata.js && node --check scripts/build-win-full.js && node --check scripts/pack-win.js",
    "tools:tessdata": "node scripts/ensure-tessdata.js --download",
    "tools:tessdata:check": "node scripts/ensure-tessdata.js --require-full"
  },
  "devDependencies": {
    "electron": "41.3.0",
    "electron-builder": "26.8.1"
  },
  "dependencies": {
    "@napi-rs/canvas": "^1.0.2",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.6.205"
  }
}
